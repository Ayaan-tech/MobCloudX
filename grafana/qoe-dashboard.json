{
	"id": null,
	"uid": "mobcloudx-prometheus",
	"title": "MobCloudX Service Observability",
	"tags": ["mobcloudx", "prometheus", "latency", "cpu", "memory"],
	"timezone": "browser",
	"schemaVersion": 39,
	"version": 1,
	"refresh": "10s",
	"editable": true,
	"graphTooltip": 0,
	"time": {
		"from": "now-1h",
		"to": "now"
	},
	"panels": [
		{
			"id": 1,
			"type": "stat",
			"title": "P95 HTTP Latency (s)",
			"gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
					"legendFormat": "p95"
				}
			],
			"fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
		},
		{
			"id": 2,
			"type": "stat",
			"title": "P55 HTTP Latency (s)",
			"gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "histogram_quantile(0.55, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
					"legendFormat": "p55"
				}
			],
			"fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
		},
		{
			"id": 3,
			"type": "stat",
			"title": "Producer RSS Memory",
			"gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "producer_process_resident_memory_bytes",
					"legendFormat": "producer"
				}
			],
			"fieldConfig": { "defaults": { "unit": "bytes" } }
		},
		{
			"id": 4,
			"type": "stat",
			"title": "Consumer RSS Memory",
			"gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "consumer_process_resident_memory_bytes",
					"legendFormat": "consumer"
				}
			],
			"fieldConfig": { "defaults": { "unit": "bytes" } }
		},
		{
			"id": 5,
			"type": "timeseries",
			"title": "HTTP Latency P95/P55 by Route",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le, route))",
					"legendFormat": "p95 {{route}}"
				},
				{
					"refId": "B",
					"expr": "histogram_quantile(0.55, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le, route))",
					"legendFormat": "p55 {{route}}"
				}
			],
			"fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
		},
		{
			"id": 6,
			"type": "timeseries",
			"title": "Request Rate by Route",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "sum by (job, method, route, status_code) (rate(http_server_request_duration_seconds_count[5m]))",
					"legendFormat": "{{job}} {{method}} {{route}} {{status_code}}"
				}
			],
			"fieldConfig": { "defaults": { "unit": "reqps" } }
		},
		{
			"id": 7,
			"type": "timeseries",
			"title": "Container CPU Usage (cAdvisor)",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\".*mcx-(producer|consumer).*\"}[5m])) * 100",
					"legendFormat": "{{name}}"
				}
			],
			"fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 } }
		},
		{
			"id": 8,
			"type": "timeseries",
			"title": "Container Memory Usage (cAdvisor)",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"refId": "A",
					"expr": "container_memory_usage_bytes{name=~\".*mcx-(producer|consumer).*\"}",
					"legendFormat": "{{name}}"
				}
			],
			"fieldConfig": { "defaults": { "unit": "bytes" } }
		}
	]
}
